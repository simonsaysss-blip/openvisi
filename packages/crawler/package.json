{
  "name": "@openvisi/crawler",
  "version": "0.1.0",
  "description": "Static crawler and canonical snapshot adapters for OpenVisi AI Visibility diagnostics.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/simonsaysss-blip/openvisi.git",
    "directory": "packages/crawler"
  },
  "keywords": [
    "ai-visibility",
    "llm-search",
    "ai-search",
    "crawler"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --target node22 --dts --clean --external package.json"
  },
  "dependencies": {
    "@openvisi/core": "0.1.0",
    "cheerio": "^1.0.0",
    "fast-xml-parser": "^5.8.0",
    "robots-parser": "^3.0.1"
  }
}
